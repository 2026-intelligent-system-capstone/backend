ENV=dev

# App
APP_NAME=Dialearn
APP_DESCRIPTION='Conversational AI learning competency assessment platform'
APP_VERSION=0.1.0
API_PREFIX=/api
DOCS_URL=/api/docs
REDOC_URL=/api/redoc
OPENAPI_URL=/api/openapi.json

# JWT
ALGORITHM=HS256
ACCESS_TOKEN_SECRET_KEY=very-secret-key-change-it-in-prod
REFRESH_TOKEN_SECRET_KEY=very-secret-key-change-it-in-prod
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080
ACCESS_TOKEN_COOKIE_NAME=access_token
REFRESH_TOKEN_COOKIE_NAME=refresh_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# Storage
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_REGION_NAME=auto

# Runtime
DEBUG=true
SQLALCHEMY_ECHO=true
FRONTEND_CORS_ORIGIN=[]
LOG_LEVEL=DEBUG
LOG_FORMAT=uvicorn
LOG_DEBUG=true

# RDBMS
DATABASE_URL=postgresql+asyncpg://postgres:password@127.0.0.1:55432/dev_db

# In-Memory Database
VALKEY_URL=redis://localhost:6379/0
